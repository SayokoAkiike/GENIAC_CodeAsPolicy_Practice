# Copy this file to .env and fill in values only if/when you add an external
# LLM planner in a later phase. Nothing in the current version of this
# project requires any of these keys -- every CLI command and test works
# with no API key set at all.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Free tier available, no credit card required: https://aistudio.google.com/apikey
GEMINI_API_KEY=
MODEL_NAME=

# Optional: override the default log level (DEBUG, INFO, WARNING, ERROR)
GENIAC_CAP_LOG_LEVEL=INFO

# Optional: override the random seed used where randomness applies
GENIAC_CAP_SEED=42
